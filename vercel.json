{
    "version": 2,
    "builds": [
        {
            "src": "backend/app/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "ptafi-frontend/package.json",
            "use": "@vercel/next"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/app/main.py"
        },
        {
            "source": "/_next/(.*)",
            "destination": "/ptafi-frontend/_next/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/ptafi-frontend/$1"
        }
    ]
}